# ==========================================
# KIDIO Environment Variables Template
# Copy this file to '.env' and fill in your secrets.
# For Render deployment, configure these keys in Render's Env Settings.
# ==========================================

# Database Connection
ConnectionStrings__DefaultConnection="Host=YOUR_DB_HOST;Database=YOUR_DB_NAME;Username=YOUR_DB_USER;Password=YOUR_DB_PASSWORD;"

# JWT Settings
JwtSettings__SecretKey="YOUR_SUPER_SECRET_KEY_MIN_32_CHARS"
JwtSettings__Issuer="KIDIO"
JwtSettings__Audience="KIDIO-Client"

# Google OAuth
GoogleOAuth__ClientId="YOUR_GOOGLE_CLIENT_ID"
GoogleOAuth__ClientSecret="YOUR_GOOGLE_CLIENT_SECRET"

# Azure Speech Service
AzureSpeech__AzureSpeechKey="YOUR_AZURE_SPEECH_KEY"
AzureSpeech__AzureSpeechRegion="southeastasia"

# Email Settings (Gmail App Password)
EmailSettings__SenderEmail="YOUR_SENDER_EMAIL"
EmailSettings__AppPassword="YOUR_GMAIL_APP_PASSWORD"

# URL Settings
UrlSettings__FrontendUrl="https://YOUR_FRONTEND_DOMAIN"
UrlSettings__BackendUrl="https://YOUR_BACKEND_DOMAIN"
